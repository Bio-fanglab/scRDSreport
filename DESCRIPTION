    BiocParallel,
    DT,
    Matrix,
    SCP (>= 0.5.6),
    Seurat,
    SeuratObject,
    ggplot2 (>= 3.4.0),
    ggsci,
    htmltools,
    jsonlite,
    knitr,
    methods,
    stats,
    tools,
    utils
Suggests:
    quarto,
    SingleCellExperiment,
    SummarizedExperiment,
    testthat (>= 3.0.0)
Remotes:
    zhanghao-njmu/SCP
URL: https://github.com/Bio-fanglab/scRDSreport
BugReports: https://github.com/Bio-fanglab/scRDSreport/issues
SystemRequirements: Quarto CLI (>= 1.3)
Config/testthat/edition: 3
Config/roxygen2/version: 8.0.0
